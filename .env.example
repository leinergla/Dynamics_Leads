# Copia este archivo a .env y ajusta los valores. docker-compose lo lee automáticamente.

# Contraseña de PostgreSQL (la usa la BD y la cadena de conexión del API).
POSTGRES_PASSWORD=postgres

# Clave de firma del JWT (mínimo 32 caracteres). ¡Usa un secreto fuerte en producción!
JWT_KEY=clave_de_desarrollo_cambiala_por_un_secreto_de_32+

# Cookie Secure: false en local (HTTP), true detrás de HTTPS.
JWT_COOKIE_SECURE=false

# Credenciales del usuario administrador inicial (se crea al primer arranque).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123*
